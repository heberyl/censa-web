---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const {
  title = 'CENSA — Especialistas en Media Tensión | Nuevo León, México',
  description = 'Empresa líder en servicios eléctricos de media tensión en Nuevo León. Instalación, mantenimiento, subestaciones y respuesta de emergencias. Certificados NOM y CFE. Tel: 812 2358545',
  image = '/assets/images/og-censa.webp',
  canonical = Astro.url.href,
} = Astro.props;

const siteUrl = 'https://censa-web.pages.dev';
const ogImage = `${siteUrl}${image}`;

const jsonLdOrganization = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'CENSA',
  legalName: 'Construcciones Eléctricas del Noreste S.A.',
  url: siteUrl,
  logo: `${siteUrl}/favicon.svg`,
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+52-812-235-8545',
    contactType: 'customer service',
    availableLanguage: 'Spanish',
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'San Isaac 1201, Residencial San Cristobal 3er Sector',
    addressLocality: 'San Nicolás de los Garza',
    addressRegion: 'Nuevo León',
    postalCode: '66478',
    addressCountry: 'MX',
  },
};

const jsonLdLocalBusiness = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'CENSA',
  description,
  telephone: '+52-812-235-8545',
  email: 'admon@censa.mx',
  url: siteUrl,
  address: jsonLdOrganization.address,
  geo: { '@type': 'GeoCoordinates', latitude: 25.7473, longitude: -100.2747 },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday'],
    opens: '08:00',
    closes: '18:00',
  },
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="CENSA" />
    <meta name="keywords" content="empresa eléctrica media tensión Monterrey, mantenimiento subestaciones Nuevo León, instalación líneas media tensión, servicios eléctricos industriales CFE" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="CENSA — Especialistas en Media Tensión" />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:site_name" content="CENSA" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Icons & Theme -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#CC0000" />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdOrganization)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdLocalBusiness)} />
  </head>
  <body>
    <slot />

    <!-- Lenis Smooth Scroll + GSAP global init -->
    <script>
      import Lenis from 'lenis';
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReducedMotion) {
        const lenis = new Lenis({
          lerp: 0.08,
          wheelMultiplier: 1.1,
          touchMultiplier: 1.5,
        });

        lenis.on('scroll', ScrollTrigger.update);

        gsap.ticker.add((time) => {
          lenis.raf(time * 1000);
        });

        gsap.ticker.lagSmoothing(0);

        (window as any).lenis = lenis;
      }
    </script>
  </body>
</html>
