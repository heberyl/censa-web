---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Loader from '../components/ui/Loader.astro';
import Hero from '../components/sections/Hero.astro';
import WhyUs from '../components/sections/WhyUs.astro';
import Services from '../components/sections/Services.astro';
import WorkProcess from '../components/sections/WorkProcess.astro';
import Projects from '../components/sections/Projects.astro';
import Certifications from '../components/sections/Certifications.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import Contact from '../components/sections/Contact.astro';
import WhatsAppFAB from '../components/layout/WhatsAppFAB.astro';
---

<BaseLayout>
  <Loader />
  <Header />
  <main id="main-content">
    <Hero />
    <WhyUs />
    <Services />
    <WorkProcess />
    <Projects />
    <Certifications />
    <Testimonials />
    <Contact />
  </main>
  <Footer />
  <WhatsAppFAB />
</BaseLayout>
