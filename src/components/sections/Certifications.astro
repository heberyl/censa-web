---
const certs = [
  { abbr: 'NOM', name: 'NOM-001-SEDE', desc: 'Instalaciones eléctricas' },
  { abbr: 'CFE', name: 'CFE Proveedor', desc: 'Comisión Federal de Electricidad' },
  { abbr: 'STPS', name: 'STPS', desc: 'Seguridad y salud en el trabajo' },
  { abbr: 'ANCE', name: 'ANCE', desc: 'Verificación de instalaciones' },
  { abbr: 'ISO', name: 'ISO 9001', desc: 'Gestión de calidad' },
];
---

<section class="cert-section">
  <div class="container-site">
    <div class="cert-inner">

      <p class="cert-ttl">Certificaciones<br/>y normas<br/>aplicadas</p>

      <div class="cert-row">
        {certs.map((c) => (
          <div class="cert-cell">
            <span class="cert-abbr">{c.abbr}</span>
            <span class="cert-name">{c.name}</span>
            <span class="cert-desc">{c.desc}</span>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .cert-section {
    padding-block: clamp(2rem, 4vw, 3.5rem);
    background: #ffffff;
    border-top: 1px solid rgba(0,0,0,.08);
    border-bottom: 1px solid rgba(0,0,0,.08);
  }

  .cert-inner {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2.4rem;
    align-items: center;
  }

  .cert-ttl {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: #999;
    line-height: 1.6;
    max-width: 14ch;
    flex-shrink: 0;
  }

  .cert-row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    border-left: 1px solid rgba(0,0,0,.1);
  }

  .cert-cell {
    padding: 1.1rem 1.4rem;
    border-right: 1px solid rgba(0,0,0,.1);
    display: flex;
    flex-direction: column;
    gap: .3rem;
    cursor: default;
    transition: background .2s ease;
  }
  .cert-cell:hover { background: #ECE8DF; }

  .cert-abbr {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.15rem;
    letter-spacing: .04em;
    color: var(--color-red);
    line-height: 1;
  }

  .cert-name {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .04em;
    font-size: .9rem;
    color: #0a0a0a;
    line-height: 1.1;
  }

  .cert-desc {
    font-size: .78rem;
    color: #888;
    line-height: 1.4;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .cert-inner { grid-template-columns: 1fr; gap: 1.2rem; }
    .cert-row { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 600px) {
    .cert-row { grid-template-columns: repeat(2, 1fr); }
  }

  @media (prefers-reduced-motion: reduce) {
    .cert-cell { transition: none; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion) {
    gsap.registerPlugin(ScrollTrigger);
    gsap.fromTo(
      '.cert-inner',
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out',
        scrollTrigger: { trigger: '.cert-section', start: 'top 88%' } },
    );
  }
</script>
