---
const testimonials = [
  {
    quote: 'CENSA realizó la instalación completa de nuestra red de distribución interna en menos tiempo del estimado, sin interrupciones en nuestra operación. La coordinación con CFE fue impecable.',
    author: 'Ing. Roberto Garza',
    role: 'Gerente de Mantenimiento',
    company: 'Industrias del Noreste S.A. de C.V.',
    initial: 'R',
    metric: '72h',
    metricLabel: 'de instalación sin detener la planta de producción',
  },
  {
    quote: 'Contratamos a CENSA para el mantenimiento anual de nuestras subestaciones y el servicio superó nuestras expectativas. Entregaron reportes técnicos detallados y atendieron observaciones en tiempo récord.',
    author: 'Arq. Laura Martínez',
    role: 'Directora de Operaciones',
    company: 'Desarrolladora Plaza Norte',
    initial: 'L',
    metric: null,
    metricLabel: null,
  },
  {
    quote: 'Tuvimos una falla de media tensión un domingo por la noche y CENSA respondió en menos de 90 minutos. Restauraron el servicio antes de que llegara el turno del lunes. Profesionales de verdad.',
    author: 'Lic. Carlos Hernández',
    role: 'Director General',
    company: 'Logística Express Monterrey',
    initial: 'C',
    metric: null,
    metricLabel: null,
  },
];

const featured = testimonials[0];
const rest = testimonials.slice(1);
---

<section class="tst-section">
  <div class="container-site">

    <!-- Encabezado -->
    <div class="tst-lead">
      <div>
        <p class="tst-kicker">Testimonios</p>
        <h2 class="tst-h2">
          Lo que dicen nuestros <em>clientes</em>.
        </h2>
      </div>
      <p class="tst-sub">
        Operadores, directores y responsables de mantenimiento que
        confían su continuidad operativa a CENSA.
      </p>
    </div>

    <!-- Testimonio destacado -->
    <div class="tst-featured">
      <div class="tst-feat-img" aria-hidden="true">
        <span class="tst-feat-label">{featured.company}</span>
      </div>
      <div class="tst-feat-body">
        <div class="tst-metric">
          <span class="tst-metric-v">{featured.metric}</span>
          <span class="tst-metric-l">{featured.metricLabel}</span>
        </div>
        <blockquote class="tst-feat-quote">
          "{featured.quote}"
        </blockquote>
        <footer class="tst-author">
          <div class="tst-av" aria-hidden="true">{featured.initial}</div>
          <div>
            <div class="tst-name">{featured.author}</div>
            <div class="tst-role">{featured.role} · {featured.company}</div>
          </div>
        </footer>
      </div>
    </div>

    <!-- Mini testimonios -->
    <div class="tst-more">
      {rest.map((t) => (
        <article class="tst-mini">
          <blockquote class="tst-mini-quote">"{t.quote}"</blockquote>
          <footer class="tst-author tst-author-mini">
            <div class="tst-av tst-av-sm" aria-hidden="true">{t.initial}</div>
            <div>
              <div class="tst-name">{t.author}</div>
              <div class="tst-role">{t.role} · {t.company}</div>
            </div>
          </footer>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .tst-section {
    padding-block: clamp(4rem, 8vw, 7rem);
    background: #ECE8DF;
  }

  /* Kicker */
  .tst-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: #0a0a0a;
    margin-bottom: .9rem;
    display: flex;
    align-items: center;
    gap: .5rem;
  }
  .tst-kicker::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--color-red);
    flex-shrink: 0;
  }

  /* Lead */
  .tst-lead {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 3rem;
    align-items: end;
    margin-bottom: 2.2rem;
  }

  .tst-h2 {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    font-size: clamp(1.8rem, 3.8vw, 3.2rem);
    line-height: .97;
    color: #0a0a0a;
    max-width: 16ch;
  }
  .tst-h2 em { font-style: normal; color: var(--color-red); }

  .tst-sub {
    color: #6b6b6b;
    font-size: .95rem;
    line-height: 1.65;
    max-width: 36ch;
  }

  /* Featured */
  .tst-featured {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    background: #ffffff;
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 14px;
    overflow: hidden;
  }

  .tst-feat-img {
    min-height: 380px;
    background:
      repeating-linear-gradient(135deg, #d6d1c6 0 10px, #ccc7ba 10px 20px);
    position: relative;
    display: flex;
    align-items: flex-end;
    padding: 1rem;
  }

  .tst-feat-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .14em;
    text-transform: uppercase;
    background: #fff;
    color: #0a0a0a;
    padding: .3rem .6rem;
    border-radius: 4px;
  }

  .tst-feat-body {
    padding: 2.2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.4rem;
  }

  .tst-metric {
    display: flex;
    align-items: baseline;
    gap: .8rem;
  }
  .tst-metric-v {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 4rem;
    color: var(--color-red);
    line-height: 1;
  }
  .tst-metric-l {
    font-size: .88rem;
    color: #6b6b6b;
    max-width: 20ch;
    line-height: 1.45;
  }

  .tst-feat-quote {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.1rem, 1.6cqw, 1.5rem);
    line-height: 1.25;
    text-transform: uppercase;
    letter-spacing: .01em;
    color: #0a0a0a;
  }

  /* Author shared */
  .tst-author {
    display: flex;
    align-items: center;
    gap: .9rem;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(0,0,0,.1);
  }
  .tst-author-mini { padding-top: .9rem; margin-top: auto; }

  .tst-av {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: var(--color-red);
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.1rem;
    flex-shrink: 0;
  }
  .tst-av-sm { width: 34px; height: 34px; font-size: .9rem; }

  .tst-name { font-weight: 600; font-size: .95rem; color: #0a0a0a; }
  .tst-role { font-size: .8rem; color: #888; margin-top: .1rem; }

  /* More mini cards */
  .tst-more {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 1.2rem;
  }

  .tst-mini {
    background: #ffffff;
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 10px;
    padding: 1.4rem;
    display: flex;
    flex-direction: column;
    gap: .9rem;
  }

  .tst-mini-quote {
    font-size: .92rem;
    line-height: 1.6;
    color: #444;
    flex: 1;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .tst-lead { grid-template-columns: 1fr; gap: 1rem; }
    .tst-featured { grid-template-columns: 1fr; }
    .tst-feat-img { min-height: 220px; }
    .tst-more { grid-template-columns: 1fr; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion) {
    gsap.registerPlugin(ScrollTrigger);

    gsap.fromTo(
      '.tst-lead',
      { opacity: 0, y: 24 },
      { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out',
        scrollTrigger: { trigger: '.tst-section', start: 'top 78%' } },
    );

    gsap.fromTo(
      '.tst-featured',
      { opacity: 0, y: 32 },
      { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
        scrollTrigger: { trigger: '.tst-featured', start: 'top 82%' } },
    );

    gsap.fromTo(
      '.tst-mini',
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.6, stagger: 0.1, ease: 'power3.out',
        scrollTrigger: { trigger: '.tst-more', start: 'top 85%' } },
    );
  }
</script>
