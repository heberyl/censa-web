---
import { company } from '../../data/company';
---

<section id="contacto" class="contact-section section-pad" style="background: #F5F5F5">
  <div class="container-site">

    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-start">

      <!-- Left: CTA text + contact info -->
      <div>
        <span class="tag mb-4 gsap-fade-up">Contacto</span>
        <h2 class="text-display mb-6 gsap-fade-up" style="font-size: clamp(2.5rem, 6vw, 5rem); color: #0a0a0a">
          ¿Tienes un proyecto de
          <span style="color: var(--color-red)"> media tensión?</span>
          Hablemos.
        </h2>
        <p class="text-base leading-relaxed mb-10 gsap-fade-up" style="color: #666666">
          Cuéntanos sobre tu proyecto y nuestro equipo de ingeniería te
          contactará en menos de 24 horas con una evaluación inicial sin costo.
        </p>

        <!-- Contact details -->
        <div class="space-y-6 gsap-fade-up">
          <a
            href={`tel:+52${company.contact.phone.replace(/\s/g,'')}`}
            class="flex items-center gap-4 group"
          >
            <div class="w-12 h-12 flex-shrink-0 flex items-center justify-center"
                 style="background: rgba(204,0,0,0.12); border: 1px solid rgba(204,0,0,0.3)">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" stroke="var(--color-red)" stroke-width="1.5" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <div class="text-xs uppercase tracking-widest mb-0.5" style="color: #666666">Teléfono</div>
              <div class="font-bold text-base transition-colors group-hover:text-red-400" style="color: white; font-family: var(--font-display); letter-spacing: 0.05em">
                {company.contact.phone}
              </div>
            </div>
          </a>

          <a
            href={`mailto:${company.contact.email}`}
            class="flex items-center gap-4 group"
          >
            <div class="w-12 h-12 flex-shrink-0 flex items-center justify-center"
                 style="background: rgba(204,0,0,0.12); border: 1px solid rgba(204,0,0,0.3)">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M2.94 4h14.12A1.94 1.94 0 0119 5.94v8.12A1.94 1.94 0 0117.06 16H2.94A1.94 1.94 0 011 14.06V5.94A1.94 1.94 0 012.94 4z" stroke="var(--color-red)" stroke-width="1.5"/>
                <path d="M1 5.5l9 6 9-6" stroke="var(--color-red)" stroke-width="1.5"/>
              </svg>
            </div>
            <div>
              <div class="text-xs uppercase tracking-widest mb-0.5" style="color: #666666">Correo</div>
              <div class="font-bold text-base transition-colors group-hover:text-red-400" style="color: white">
                {company.contact.email}
              </div>
            </div>
          </a>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 flex-shrink-0 flex items-center justify-center"
                 style="background: rgba(204,0,0,0.12); border: 1px solid rgba(204,0,0,0.3)">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M10 2C6.686 2 4 4.686 4 8c0 4.875 6 10 6 10s6-5.125 6-10c0-3.314-2.686-6-6-6zm0 8a2 2 0 110-4 2 2 0 010 4z" stroke="var(--color-red)" stroke-width="1.5"/>
              </svg>
            </div>
            <div>
              <div class="text-xs uppercase tracking-widest mb-0.5" style="color: #666666">Dirección</div>
              <address class="not-italic text-sm leading-relaxed" style="color: var(--color-gray-200)">
                {company.address.street},<br />
                {company.address.colony},<br />
                C.P. {company.address.zip} {company.address.city},<br />
                {company.address.state}, {company.address.country}
              </address>
            </div>
          </div>
        </div>

        <!-- Social links -->
        <div class="flex gap-4 mt-10 gsap-fade-up">
          <a href={company.social.facebook} aria-label="Facebook de CENSA" target="_blank" rel="noopener noreferrer"
             class="w-10 h-10 flex items-center justify-center border transition-all duration-200 hover:border-red-600"
             style="border-color: rgba(255,255,255,0.12); color: var(--color-gray-400)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href={company.social.linkedin} aria-label="LinkedIn de CENSA" target="_blank" rel="noopener noreferrer"
             class="w-10 h-10 flex items-center justify-center border transition-all duration-200 hover:border-red-600"
             style="border-color: rgba(255,255,255,0.12); color: var(--color-gray-400)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href={company.social.youtube} aria-label="YouTube de CENSA" target="_blank" rel="noopener noreferrer"
             class="w-10 h-10 flex items-center justify-center border transition-all duration-200 hover:border-red-600"
             style="border-color: rgba(255,255,255,0.12); color: var(--color-gray-400)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: Contact form -->
      <div class="contact-form-wrap gsap-slide-right">
        <div class="p-8 lg:p-10 border bg-white" style="border-color: rgba(0,0,0,0.08)">
          <h3 class="text-xl font-bold uppercase tracking-wide mb-2" style="font-family: var(--font-display); color: #0a0a0a">
            Solicitar cotización
          </h3>
          <p class="text-sm mb-8" style="color: #666666">
            Respuesta garantizada en menos de 24 horas hábiles.
          </p>

          <form
            id="contact-form"
            class="space-y-5"
            novalidate
          >
            <!-- Web3Forms hidden fields -->
            <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_WEB3FORMS_KEY ?? 'YOUR_WEB3FORMS_KEY'} />
            <input type="hidden" name="subject" value="Nueva solicitud desde CENSA Web" />
            <input type="hidden" name="from_name" value="CENSA Website" />
            <input type="checkbox" name="botcheck" style="display:none" />

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="contact-name" class="block text-xs uppercase tracking-widest mb-2" style="color: #666666">
                  Nombre *
                </label>
                <input
                  type="text"
                  id="contact-name"
                  name="name"
                  required
                  placeholder="Juan Rodríguez"
                  class="form-input w-full px-4 py-3 text-sm border outline-none transition-all duration-200"
                  style="background: white; border-color: rgba(0,0,0,0.12); color: #0a0a0a"
                />
              </div>
              <div>
                <label for="contact-company" class="block text-xs uppercase tracking-widest mb-2" style="color: #666666">
                  Empresa
                </label>
                <input
                  type="text"
                  id="contact-company"
                  name="company"
                  placeholder="Mi Empresa S.A."
                  class="form-input w-full px-4 py-3 text-sm border outline-none transition-all duration-200"
                  style="background: white; border-color: rgba(0,0,0,0.12); color: #0a0a0a"
                />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="contact-email" class="block text-xs uppercase tracking-widest mb-2" style="color: #666666">
                  Correo electrónico *
                </label>
                <input
                  type="email"
                  id="contact-email"
                  name="email"
                  required
                  placeholder="correo@empresa.com"
                  class="form-input w-full px-4 py-3 text-sm border outline-none transition-all duration-200"
                  style="background: white; border-color: rgba(0,0,0,0.12); color: #0a0a0a"
                />
              </div>
              <div>
                <label for="contact-phone" class="block text-xs uppercase tracking-widest mb-2" style="color: #666666">
                  Teléfono
                </label>
                <input
                  type="tel"
                  id="contact-phone"
                  name="phone"
                  placeholder="81 1234 5678"
                  class="form-input w-full px-4 py-3 text-sm border outline-none transition-all duration-200"
                  style="background: white; border-color: rgba(0,0,0,0.12); color: #0a0a0a"
                />
              </div>
            </div>

            <div>
              <label for="contact-service" class="block text-xs uppercase tracking-widest mb-2" style="color: #666666">
                Servicio requerido
              </label>
              <select
                id="contact-service"
                name="service"
                class="form-input w-full px-4 py-3 text-sm border outline-none transition-all duration-200 appearance-none cursor-pointer"
                style="background: white; border-color: rgba(0,0,0,0.12); color: #0a0a0a"
              >
                <option value="">Seleccionar servicio...</option>
                <option>Instalación de Líneas de Media Tensión</option>
                <option>Mantenimiento Preventivo y Correctivo</option>
                <option>Subestaciones Eléctricas</option>
                <option>Respuesta a Emergencias</option>
                <option>Ingeniería y Proyectos</option>
                <option>Inspección y Pruebas</option>
                <option>Otro</option>
              </select>
            </div>

            <div>
              <label for="contact-message" class="block text-xs uppercase tracking-widest mb-2" style="color: #666666">
                Descripción del proyecto *
              </label>
              <textarea
                id="contact-message"
                name="message"
                required
                rows="4"
                placeholder="Describe brevemente tu proyecto o necesidad eléctrica..."
                class="form-input w-full px-4 py-3 text-sm border outline-none transition-all duration-200 resize-none"
                style="background: white; border-color: rgba(0,0,0,0.12); color: #0a0a0a"
              ></textarea>
            </div>

            <!-- Submit -->
            <button type="submit" id="submit-btn" class="btn-primary w-full justify-center">
              <span id="submit-text">Enviar solicitud</span>
              <svg id="submit-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <!-- Loading spinner (hidden by default) -->
              <svg id="submit-spinner" class="hidden animate-spin" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="2" stroke-dasharray="28" stroke-dashoffset="14" stroke-linecap="round"/>
              </svg>
            </button>

            <!-- Messages -->
            <div id="form-success" class="hidden p-4 text-sm text-center" style="background: rgba(0,160,0,0.12); border: 1px solid rgba(0,160,0,0.3); color: #4ade80" role="alert">
              ¡Mensaje enviado! Te contactaremos en menos de 24 horas.
            </div>
            <div id="form-error" class="hidden p-4 text-sm text-center" style="background: rgba(204,0,0,0.12); border: 1px solid rgba(204,0,0,0.3); color: var(--color-red-light)" role="alert">
              Hubo un error al enviar. Por favor llámanos directamente al 812 2358545.
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .form-input::placeholder { color: #bbbbbb; }
  .form-input:focus {
    border-color: rgba(204, 0, 0, 0.6) !important;
    box-shadow: 0 0 0 3px rgba(204, 0, 0, 0.1);
  }
  .animate-spin { animation: spin 1s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) {
    .animate-spin { animation: none; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion) {
    gsap.registerPlugin(ScrollTrigger);
    gsap.to('.contact-section .gsap-fade-up', {
      opacity: 1, y: 0, duration: 0.7, stagger: 0.12, ease: 'power3.out',
      scrollTrigger: { trigger: '.contact-section', start: 'top 75%' },
    });
    gsap.to('.contact-form-wrap', {
      opacity: 1, x: 0, duration: 0.8, ease: 'power3.out',
      scrollTrigger: { trigger: '.contact-section', start: 'top 70%' },
    });
  }

  // Form submission via Web3Forms
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn  = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitText = document.getElementById('submit-text')!;
  const submitIcon = document.getElementById('submit-icon')!;
  const submitSpinner = document.getElementById('submit-spinner')!;
  const successMsg = document.getElementById('form-success')!;
  const errorMsg   = document.getElementById('form-error')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Loading state
    submitBtn.disabled = true;
    submitText.textContent = 'Enviando...';
    submitIcon.classList.add('hidden');
    submitSpinner.classList.remove('hidden');
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    try {
      const formData = new FormData(form);
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: formData,
      });
      const data = await res.json();

      if (data.success) {
        successMsg.classList.remove('hidden');
        form.reset();
      } else {
        throw new Error(data.message);
      }
    } catch {
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitText.textContent = 'Enviar solicitud';
      submitIcon.classList.remove('hidden');
      submitSpinner.classList.add('hidden');
    }
  });
</script>
