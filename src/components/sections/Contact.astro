---
import { company } from '../../data/company';
---

<section id="contacto" class="ct-section">
  <div class="container-site">

    <!-- Encabezado: ancho completo, encima del grid -->
    <div class="ct-header">
      <div>
        <p class="ct-kicker">Contacto</p>
        <h2 class="ct-h2">
          ¿Tienes un proyecto de <em>media tensión</em>?<br/>
          Hablemos.
        </h2>
      </div>
      <p class="ct-intro">
        Cuéntanos sobre tu proyecto y nuestro equipo de ingeniería te
        contactará en menos de 24 horas con una evaluación inicial sin costo.
      </p>
    </div>

    <!-- Grid: info izquierda | form derecha -->
    <div class="ct-grid">

      <!-- Columna izquierda: datos + emergencia + mapa -->
      <div class="ct-left">

        <!-- Datos de contacto -->
        <div class="ct-details">
          <a href={`tel:+52${company.contact.phone.replace(/\s/g,'')}`} class="ct-item ct-item-link">
            <div class="ct-icon">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" stroke="var(--color-red)" stroke-width="1.5" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <div class="ct-item-label">Teléfono</div>
              <div class="ct-item-value">{company.contact.phone}</div>
            </div>
          </a>

          <a href={`mailto:${company.contact.email}`} class="ct-item ct-item-link">
            <div class="ct-icon">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M2.94 4h14.12A1.94 1.94 0 0119 5.94v8.12A1.94 1.94 0 0117.06 16H2.94A1.94 1.94 0 011 14.06V5.94A1.94 1.94 0 012.94 4z" stroke="var(--color-red)" stroke-width="1.5"/>
                <path d="M1 5.5l9 6 9-6" stroke="var(--color-red)" stroke-width="1.5"/>
              </svg>
            </div>
            <div>
              <div class="ct-item-label">Correo</div>
              <div class="ct-item-value">{company.contact.email}</div>
            </div>
          </a>

          <div class="ct-item">
            <div class="ct-icon">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M10 2C6.686 2 4 4.686 4 8c0 4.875 6 10 6 10s6-5.125 6-10c0-3.314-2.686-6-6-6zm0 8a2 2 0 110-4 2 2 0 010 4z" stroke="var(--color-red)" stroke-width="1.5"/>
              </svg>
            </div>
            <div>
              <div class="ct-item-label">Dirección</div>
              <address class="ct-item-value ct-address">
                {company.address.street},<br/>
                {company.address.colony},<br/>
                C.P. {company.address.zip} {company.address.city}, {company.address.state}
              </address>
            </div>
          </div>
        </div>

        <!-- Banda emergencia 24/7 -->
        <div class="ct-emergency">
          <div class="ct-emrg-left">
            <div class="ct-emrg-label">
              <span class="ct-emrg-dot" aria-hidden="true"></span>
              Emergencia 24/7
            </div>
            <div class="ct-emrg-num">{company.contact.phone}</div>
          </div>
          <p class="ct-emrg-note">Respuesta &lt; 2h en el AMM</p>
        </div>

        <!-- Mapa de cobertura -->
        <div class="ct-map">
          <div class="ct-map-hd">
            <h4 class="ct-map-title">Zona de cobertura</h4>
            <span class="ct-map-tag">Nuevo León · AMM</span>
          </div>
          <div class="ct-map-viz">
            <svg viewBox="0 0 400 200" preserveAspectRatio="xMidYMid meet" aria-label="Mapa de cobertura del Área Metropolitana de Monterrey" role="img">
              <defs>
                <pattern id="cov-grid" width="20" height="20" patternUnits="userSpaceOnUse">
                  <path d="M 20 0 L 0 0 0 20" fill="none" stroke="currentColor" stroke-width=".5" opacity=".1"/>
                </pattern>
              </defs>
              <rect width="400" height="200" fill="url(#cov-grid)"/>
              <path d="M55 55 Q95 25 155 38 Q215 18 275 48 Q338 58 355 108 Q335 175 275 185 Q198 196 138 175 Q65 163 55 115 Z"
                    fill="var(--color-red)" opacity=".07" stroke="var(--color-red)" stroke-width="1" stroke-dasharray="3,3"/>
              <!-- Monterrey HQ -->
              <circle cx="197" cy="110" r="6" fill="var(--color-red)"/>
              <circle cx="197" cy="110" r="6" fill="none" stroke="var(--color-red)" stroke-width="1.5" opacity=".5">
                <animate attributeName="r" from="8" to="22" dur="2s" repeatCount="indefinite"/>
                <animate attributeName="opacity" from=".6" to="0" dur="2s" repeatCount="indefinite"/>
              </circle>
              <text x="197" y="100" text-anchor="middle" font-family="monospace" font-size="8" letter-spacing=".1em" fill="currentColor" opacity=".75">MONTERREY</text>
              <!-- Municipios -->
              <circle cx="232" cy="90" r="3" fill="var(--color-red)"/>
              <text x="237" y="87" font-family="monospace" font-size="6.5" fill="currentColor" opacity=".6">SAN NICOLÁS</text>
              <circle cx="268" cy="125" r="3" fill="var(--color-red)"/>
              <text x="275" y="129" font-family="monospace" font-size="6.5" fill="currentColor" opacity=".6">APODACA</text>
              <circle cx="232" cy="145" r="3" fill="var(--color-red)"/>
              <text x="237" y="153" font-family="monospace" font-size="6.5" fill="currentColor" opacity=".6">GUADALUPE</text>
              <circle cx="162" cy="140" r="3" fill="var(--color-red)"/>
              <text x="157" y="155" text-anchor="end" font-family="monospace" font-size="6.5" fill="currentColor" opacity=".6">STA. CATARINA</text>
              <circle cx="158" cy="90" r="3" fill="var(--color-red)"/>
              <text x="153" y="86" text-anchor="end" font-family="monospace" font-size="6.5" fill="currentColor" opacity=".6">ESCOBEDO</text>
              <!-- Líneas desde HQ -->
              <g stroke="var(--color-red)" stroke-width=".8" opacity=".3" fill="none" stroke-dasharray="2,3">
                <line x1="197" y1="110" x2="232" y2="90"/>
                <line x1="197" y1="110" x2="268" y2="125"/>
                <line x1="197" y1="110" x2="232" y2="145"/>
                <line x1="197" y1="110" x2="162" y2="140"/>
                <line x1="197" y1="110" x2="158" y2="90"/>
              </g>
            </svg>
          </div>
        </div>

      </div>

      <!-- Columna derecha: formulario -->
      <div class="ct-right">
        <div class="ct-form-card">
          <div class="ct-form-hd">
            <h3 class="ct-form-title">Solicitar cotización</h3>
            <span class="ct-form-sla">Respuesta &lt; 24h</span>
          </div>

          <form id="contact-form" class="ct-form" novalidate>
            <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_WEB3FORMS_KEY ?? 'YOUR_WEB3FORMS_KEY'} />
            <input type="hidden" name="subject" value="Nueva solicitud desde CENSA Web" />
            <input type="hidden" name="from_name" value="CENSA Website" />
            <input type="checkbox" name="botcheck" style="display:none" />

            <div class="ct-form-row">
              <div class="ct-field">
                <label for="ct-name">Nombre *</label>
                <input type="text" id="ct-name" name="name" required placeholder="Juan Rodríguez"/>
              </div>
              <div class="ct-field">
                <label for="ct-company">Empresa</label>
                <input type="text" id="ct-company" name="company" placeholder="Mi Empresa S.A."/>
              </div>
            </div>

            <div class="ct-form-row">
              <div class="ct-field">
                <label for="ct-email">Correo *</label>
                <input type="email" id="ct-email" name="email" required placeholder="correo@empresa.com"/>
              </div>
              <div class="ct-field">
                <label for="ct-phone">Teléfono</label>
                <input type="tel" id="ct-phone" name="phone" placeholder="81 1234 5678"/>
              </div>
            </div>

            <div class="ct-field">
              <label for="ct-service">Servicio requerido</label>
              <select id="ct-service" name="service">
                <option value="">Seleccionar servicio...</option>
                <option>Instalación de Líneas de Media Tensión</option>
                <option>Mantenimiento Preventivo y Correctivo</option>
                <option>Subestaciones Eléctricas</option>
                <option>Respuesta a Emergencias</option>
                <option>Ingeniería y Proyectos</option>
                <option>Inspección y Pruebas</option>
                <option>Otro</option>
              </select>
            </div>

            <div class="ct-field">
              <label for="ct-message">Descripción del proyecto *</label>
              <textarea id="ct-message" name="message" required rows="4"
                placeholder="Voltaje, capacidad, ubicación, plazos…"></textarea>
            </div>

            <div class="ct-submit-row">
              <span class="ct-privacy">Al enviar aceptas nuestro aviso de privacidad.</span>
              <button type="submit" id="submit-btn" class="btn-primary">
                <span id="submit-text">Enviar solicitud</span>
                <svg id="submit-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <svg id="submit-spinner" class="hidden animate-spin" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="2" stroke-dasharray="28" stroke-dashoffset="14" stroke-linecap="round"/>
                </svg>
              </button>
            </div>

            <div id="form-success" class="hidden ct-msg ct-msg-ok" role="alert">
              ¡Mensaje enviado! Te contactaremos en menos de 24 horas.
            </div>
            <div id="form-error" class="hidden ct-msg ct-msg-err" role="alert">
              Hubo un error al enviar. Por favor llámanos directamente al 812 2358545.
            </div>
          </form>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .ct-section {
    padding-block: clamp(4rem, 8vw, 7rem);
    background: #F5F5F5;
  }

  /* ── Encabezado ancho completo ── */
  .ct-header {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 3rem;
    align-items: end;
    margin-bottom: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(0,0,0,.1);
  }

  .ct-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: #0a0a0a;
    margin-bottom: .9rem;
    display: flex;
    align-items: center;
    gap: .5rem;
  }
  .ct-kicker::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--color-red);
    flex-shrink: 0;
  }

  .ct-h2 {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    font-size: clamp(1.8rem, 3.5vw, 3.2rem);
    line-height: .97;
    color: #0a0a0a;
  }
  .ct-h2 em { font-style: normal; color: var(--color-red); }

  .ct-intro {
    color: #666;
    font-size: .95rem;
    line-height: 1.7;
    max-width: 38ch;
    align-self: end;
  }

  /* ── Grid principal ── */
  .ct-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* ── Columna izquierda ── */
  .ct-details {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid rgba(0,0,0,.1);
    border-bottom: 1px solid rgba(0,0,0,.1);
    margin-bottom: 1.5rem;
  }

  .ct-item {
    display: grid;
    grid-template-columns: 44px 1fr;
    gap: 1rem;
    align-items: center;
    padding: 1.1rem 0;
    border-bottom: 1px solid rgba(0,0,0,.08);
    text-decoration: none;
    color: inherit;
  }
  .ct-item:last-child { border-bottom: 0; }

  .ct-item-link { transition: color .2s; }
  .ct-item-link:hover .ct-item-value { color: var(--color-red); }

  .ct-icon {
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(204,0,0,.1);
    border: 1px solid rgba(204,0,0,.25);
    border-radius: 8px;
    flex-shrink: 0;
  }

  .ct-item-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: .2rem;
  }

  .ct-item-value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: .02em;
    color: #0a0a0a;
    transition: color .2s;
  }

  .ct-address {
    font-style: normal;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: .875rem;
    line-height: 1.6;
    color: #555;
    letter-spacing: 0;
  }

  /* Banda emergencia */
  .ct-emergency {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.2rem;
    border: 1px solid rgba(204,0,0,.3);
    background: rgba(204,0,0,.06);
    border-radius: 8px;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .ct-emrg-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--color-red);
    display: flex;
    align-items: center;
    gap: .4rem;
    margin-bottom: .25rem;
  }

  .ct-emrg-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--color-red);
    flex-shrink: 0;
    animation: emrgPulse 1.6s infinite;
  }
  @keyframes emrgPulse { 0%, 100% { opacity: 1; } 50% { opacity: .3; } }

  .ct-emrg-num {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.25rem;
    color: #0a0a0a;
    letter-spacing: .02em;
  }

  .ct-emrg-note {
    font-size: .8rem;
    color: #888;
    text-align: right;
  }

  /* Mapa */
  .ct-map {
    background: #fff;
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 10px;
    overflow: hidden;
  }

  .ct-map-hd {
    padding: .85rem 1.1rem;
    border-bottom: 1px solid rgba(0,0,0,.08);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .ct-map-title {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .04em;
    font-size: .9rem;
    color: #0a0a0a;
  }

  .ct-map-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--color-red);
  }

  .ct-map-viz {
    aspect-ratio: 16/7;
    color: #0a0a0a;
  }
  .ct-map-viz svg { width: 100%; height: 100%; display: block; }

  /* ── Columna derecha: formulario ── */
  .ct-form-card {
    background: #fff;
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 12px;
    overflow: hidden;
  }

  .ct-form-hd {
    padding: 1.3rem 1.6rem;
    border-bottom: 1px solid rgba(0,0,0,.08);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .ct-form-title {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .04em;
    font-size: 1.1rem;
    color: #0a0a0a;
  }

  .ct-form-sla {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--color-red);
  }

  .ct-form {
    padding: 1.4rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ct-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .ct-field {
    display: flex;
    flex-direction: column;
    gap: .35rem;
  }

  .ct-field label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: #888;
  }

  .ct-field input,
  .ct-field select,
  .ct-field textarea {
    width: 100%;
    padding: .7rem .9rem;
    background: #F9F9F9;
    border: 1px solid rgba(0,0,0,.12);
    border-radius: 6px;
    font-family: var(--font-body);
    font-size: .9rem;
    color: #0a0a0a;
    outline: none;
    transition: border-color .2s, box-shadow .2s;
    appearance: none;
  }
  .ct-field input::placeholder,
  .ct-field textarea::placeholder { color: #bbb; }
  .ct-field input:focus,
  .ct-field select:focus,
  .ct-field textarea:focus {
    border-color: rgba(204,0,0,.5);
    box-shadow: 0 0 0 3px rgba(204,0,0,.08);
  }
  .ct-field textarea { resize: vertical; min-height: 96px; }

  .ct-submit-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: .4rem;
  }

  .ct-privacy {
    font-size: .78rem;
    color: #aaa;
  }

  .ct-msg {
    padding: .85rem 1rem;
    font-size: .85rem;
    text-align: center;
    border-radius: 6px;
    border: 1px solid;
  }
  .ct-msg-ok { background: rgba(0,160,0,.1); border-color: rgba(0,160,0,.3); color: #166534; }
  .ct-msg-err { background: rgba(204,0,0,.1); border-color: rgba(204,0,0,.3); color: var(--color-red); }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .ct-header { grid-template-columns: 1fr; gap: 1rem; }
    .ct-grid { grid-template-columns: 1fr; gap: 2rem; }
    .ct-form-row { grid-template-columns: 1fr; }
    .ct-submit-row { flex-direction: column; align-items: stretch; }
    .ct-submit-row .btn-primary { justify-content: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ct-emrg-dot { animation: none; }
  }

  .animate-spin { animation: spin 1s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { .animate-spin { animation: none; } }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion) {
    gsap.registerPlugin(ScrollTrigger);

    gsap.fromTo(
      '.ct-header',
      { opacity: 0, y: 24 },
      { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out',
        scrollTrigger: { trigger: '.ct-section', start: 'top 78%' } },
    );

    gsap.fromTo(
      '.ct-left',
      { opacity: 0, x: -24 },
      { opacity: 1, x: 0, duration: 0.7, ease: 'power3.out',
        scrollTrigger: { trigger: '.ct-grid', start: 'top 80%' } },
    );

    gsap.fromTo(
      '.ct-right',
      { opacity: 0, x: 24 },
      { opacity: 1, x: 0, duration: 0.7, ease: 'power3.out',
        scrollTrigger: { trigger: '.ct-grid', start: 'top 80%' } },
    );
  }

  /* ── Form submission via Web3Forms ── */
  const form        = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn   = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitText  = document.getElementById('submit-text')!;
  const submitIcon  = document.getElementById('submit-icon')!;
  const submitSpinner = document.getElementById('submit-spinner')!;
  const successMsg  = document.getElementById('form-success')!;
  const errorMsg    = document.getElementById('form-error')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitText.textContent = 'Enviando...';
    submitIcon.classList.add('hidden');
    submitSpinner.classList.remove('hidden');
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form),
      });
      const data = await res.json();
      if (data.success) {
        successMsg.classList.remove('hidden');
        form.reset();
      } else {
        throw new Error(data.message);
      }
    } catch {
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitText.textContent = 'Enviar solicitud';
      submitIcon.classList.remove('hidden');
      submitSpinner.classList.add('hidden');
    }
  });
</script>
