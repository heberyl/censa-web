---
import { company } from '../../data/company';
---

<section id="inicio" class="hero relative min-h-screen flex items-center overflow-hidden">

  <!-- Video Background -->
  <div class="hero-video-wrap absolute inset-0 z-0">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="none"
      class="absolute inset-0 w-full h-full object-cover"
      aria-hidden="true"
      poster="/assets/images/hero-poster.webp"
    >
      <source src="/assets/videos/hero-bg.mp4" type="video/mp4" />
    </video>
    <!-- Multi-layer overlay -->
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(10,10,10,0.88) 0%, rgba(10,10,10,0.70) 50%, rgba(10,10,10,0.82) 100%);"></div>
    <!-- Red glow accent bottom-left -->
    <div class="absolute bottom-0 left-0 w-96 h-96 rounded-full" style="background: radial-gradient(circle, rgba(204,0,0,0.15) 0%, transparent 70%); filter: blur(60px);"></div>
  </div>

  <!-- Decorative grid lines -->
  <div class="absolute inset-0 z-0 opacity-5" style="background-image: linear-gradient(rgba(255,255,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 60px 60px;" aria-hidden="true"></div>

  <!-- Content -->
  <div class="container-site relative z-10 py-32 lg:py-0">
    <div class="max-w-4xl">

      <!-- Badge -->
      <div class="hero-badge tag mb-6 gsap-fade-up">
        <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse" style="background:var(--color-red)"></span>
        Especialistas en Media Tensión — Nuevo León, México
      </div>

      <!-- Headline -->
      <h1 class="hero-headline text-display gsap-fade-up" style="font-size: clamp(3.5rem, 10vw, 8rem); color: white;">
        {company.tagline.split(' ').map((word, i) => (
          <span class="block" style={i === 2 ? 'color: var(--color-red)' : ''}>
            {word}
          </span>
        ))}
      </h1>

      <!-- Sub description -->
      <p class="hero-desc mt-6 text-base lg:text-lg leading-relaxed max-w-xl gsap-fade-up" style="color: var(--color-gray-200)">
        Más de 15 años construyendo la infraestructura eléctrica que impulsa a la industria de Nuevo León.
        Certificados por CFE y NOM-001-SEDE.
      </p>

      <!-- CTAs -->
      <div class="hero-ctas flex flex-wrap gap-4 mt-10 gsap-fade-up">
        <a href="#servicios" class="btn-primary">
          Ver Servicios
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M3.75 9h10.5M10.5 5.25L14.25 9l-3.75 3.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#contacto" class="btn-outline">
          Solicitar cotización
        </a>
      </div>

      <!-- Stats bar -->
      <div class="hero-stats mt-16 pt-8 border-t grid grid-cols-2 sm:grid-cols-4 gap-6 gsap-fade-up" style="border-color: rgba(255,255,255,0.1)">
        {company.stats.map((stat) => (
          <div class="text-center sm:text-left">
            <div class="text-display text-3xl lg:text-4xl" style="color: var(--color-red); font-family: var(--font-display)">
              {stat.value}
            </div>
            <div class="text-xs mt-1 uppercase tracking-widest" style="color: var(--color-gray-400)">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 gsap-fade-in" aria-hidden="true">
    <span class="text-xs tracking-widest uppercase" style="color: var(--color-gray-400)">Scroll</span>
    <div class="w-px h-12 relative overflow-hidden" style="background: rgba(255,255,255,0.15)">
      <div class="scroll-line absolute top-0 left-0 w-full bg-red-600" style="background: var(--color-red); height: 100%; animation: scrollLine 1.8s ease-in-out infinite;"></div>
    </div>
  </div>
</section>

<style>
  @keyframes scrollLine {
    0%   { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-line { animation: none; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion) {
    gsap.registerPlugin(ScrollTrigger);

    // Staggered entry animation on load
    const tl = gsap.timeline({ delay: 0.3 });
    tl.to('.hero-badge',    { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' })
      .to('.hero-headline', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, '-=0.4')
      .to('.hero-desc',     { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' }, '-=0.5')
      .to('.hero-ctas',     { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, '-=0.4')
      .to('.hero-stats',    { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, '-=0.3')
      .to('.hero-scroll',   { opacity: 1, duration: 0.5, ease: 'power2.out' }, '-=0.2');

    // Parallax on hero video
    ScrollTrigger.create({
      trigger: '.hero',
      start: 'top top',
      end: 'bottom top',
      scrub: true,
      onUpdate: (self) => {
        const video = document.querySelector('.hero-video-wrap') as HTMLElement;
        if (video) video.style.transform = `translateY(${self.progress * 120}px)`;
      },
    });
  }
</script>
