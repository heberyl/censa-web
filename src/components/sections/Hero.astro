---
import { company } from '../../data/company';
---

<section id="inicio" class="hero relative min-h-screen flex items-end overflow-hidden" style="background: #0a0a0a; padding-bottom: 28vh;">

  <!-- Image/Video Background -->
  <div class="hero-video-wrap absolute inset-0 z-0">

    <!-- Imagen siempre visible como fondo base -->
    <div
      class="absolute inset-0 bg-center bg-cover bg-no-repeat"
      style="background-image: url('/assets/images/hero-poster.webp');"
      aria-hidden="true"
    ></div>

    <!-- Video encima de la imagen cuando cargue (requiere /assets/videos/hero-bg.mp4) -->
    <video
      autoplay
      muted
      loop
      playsinline
      preload="none"
      class="absolute inset-0 w-full h-full object-cover"
      aria-hidden="true"
      onerror="this.style.display='none'"
    >
      <source src="/assets/videos/hero-bg.mp4" type="video/mp4" />
    </video>

    <!-- Overlay oscuro -->
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(5,5,5,0.52) 0%, rgba(5,5,5,0.28) 50%, rgba(5,5,5,0.45) 100%);"></div>
    <!-- Acento rojo inferior izquierdo -->
    <div class="absolute bottom-0 left-0 w-96 h-96 rounded-full" style="background: radial-gradient(circle, rgba(204,0,0,0.12) 0%, transparent 70%); filter: blur(60px);"></div>
  </div>

  <!-- Decorative grid lines -->
  <div class="absolute inset-0 z-0 opacity-5" style="background-image: linear-gradient(rgba(255,255,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 60px 60px;" aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative z-10 w-full" style="padding-left: clamp(1.25rem, 2vw, 2.5rem); padding-right: clamp(1.25rem, 2vw, 2.5rem);">
    <div class="w-full">

      <!-- Badge -->
      <div class="hero-badge tag mb-6 gsap-fade-up">
        <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse" style="background:var(--color-red)"></span>
        Especialistas en Media Tensión — Nuevo León, México
      </div>

      <!-- Headline -->
      <h1 class="hero-headline text-display gsap-fade-up" style="font-size: clamp(2.6rem, 5.5vw, 5rem); color: white; line-height: 1.05;">
        <span class="block">Infraestructura eléctrica</span>
        <span class="block">que no <span style="color: var(--color-red)">falla</span></span>
      </h1>

      <!-- Sub description -->
      <p class="hero-desc mt-6 text-base lg:text-lg leading-relaxed max-w-xl gsap-fade-up" style="color: var(--color-gray-200)">
        Más de 15 años construyendo la infraestructura eléctrica que impulsa a la industria de Nuevo León.
        Certificados por CFE y NOM-001-SEDE.
      </p>

      <!-- CTAs -->
      <div class="hero-ctas flex flex-wrap gap-4 mt-10 gsap-fade-up">
        <a href="#servicios" class="btn-primary">
          Ver Servicios
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M3.75 9h10.5M10.5 5.25L14.25 9l-3.75 3.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#contacto" class="btn-outline">
          Solicitar cotización
        </a>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 gsap-fade-in" aria-hidden="true">
    <span class="text-xs tracking-widest uppercase" style="color: rgba(255,255,255,0.35)">Scroll</span>
    <svg class="scroll-arrow" width="14" height="9" viewBox="0 0 14 9" fill="none">
      <path d="M1 1.5l6 6 6-6" stroke="var(--color-red)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</section>

<style>
  .scroll-arrow {
    animation: arrowBounce 1.5s ease-in-out infinite;
  }
  @keyframes arrowBounce {
    0%, 100% { transform: translateY(0);   opacity: 1; }
    50%       { transform: translateY(6px); opacity: 0.5; }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-arrow { animation: none; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion) {
    gsap.registerPlugin(ScrollTrigger);

    // Wait for loader to finish before animating hero
    // Loader total duration: ~0.65+0.35+0.55+0.3+0.75 ≈ 2.25s — delay matches
    // 0.9 + 0.8 + 0.45 + 1.6 ≈ 3.6s total loader
    const loaderDuration = 3.5;

    const tl = gsap.timeline({ delay: loaderDuration });
    tl.to('.hero-badge',    { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' })
      .to('.hero-headline', { opacity: 1, y: 0, duration: 0.75, ease: 'power3.out' }, '-=0.35')
      .to('.hero-desc',     { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, '-=0.45')
      .to('.hero-ctas',     { opacity: 1, y: 0, duration: 0.55, ease: 'power3.out' }, '-=0.35')
      .to('.hero-scroll',   { opacity: 1, duration: 0.4, ease: 'power2.out' }, '-=0.2');

    // Parallax on hero video
    ScrollTrigger.create({
      trigger: '.hero',
      start: 'top top',
      end: 'bottom top',
      scrub: true,
      onUpdate: (self) => {
        const video = document.querySelector('.hero-video-wrap') as HTMLElement;
        if (video) video.style.transform = `translateY(${self.progress * 120}px)`;
      },
    });
  }
</script>
