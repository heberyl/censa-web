---
const pillars = [
  {
    title: 'Certificación NOM y CFE',
    description: 'Todos nuestros trabajos cumplen con la NOM-001-SEDE y los estándares técnicos de CFE. Instalaciones que pasan cualquier verificación oficial.',
  },
  {
    title: 'Respuesta 24 / 7',
    description: 'Cuadrillas disponibles las 24 horas, los 365 días del año para emergencias eléctricas. Tiempo de respuesta menor a 2 horas en toda la zona metropolitana.',
  },
  {
    title: '+15 Años de Experiencia',
    description: 'Más de una década y media ejecutando proyectos de media tensión en Monterrey y el noreste de México. Conocimiento que se refleja en cada obra.',
  },
  {
    title: 'Cobertura Regional',
    description: 'Operamos en todo Nuevo León y estados del noreste. Conocemos la infraestructura local y los requerimientos específicos de cada municipio.',
  },
  {
    title: 'Cero Accidentes',
    description: 'Historial impecable de seguridad en todas nuestras operaciones. Personal certificado y protocolos de seguridad de clase mundial.',
  },
];
---

<section id="nosotros" class="why-section" style="background: #ECE8DF;">
  <div class="container-site">

    <div class="why-grid">

      <!-- Columna izquierda: heading -->
      <div class="why-left">
        <div class="why-left-inner">
          <span class="tag why-tag">Por qué elegirnos</span>

          <h2 class="why-heading text-display">
            La elección<br/>
            <span style="color: var(--color-red)">inteligente</span><br/>
            para tu industria
          </h2>

          <p class="why-desc">
            Cinco razones que nos posicionan como la empresa de referencia en
            servicios eléctricos de media tensión en Nuevo León.
          </p>

          <div class="why-stat">
            <div class="why-stat-value">+200</div>
            <div class="why-stat-label">Proyectos completados<br/>en el noreste de México</div>
          </div>
        </div>
      </div>

      <!-- Columna derecha: lista de pilares -->
      <div class="why-right">
        {pillars.map((pillar, i) => (
          <div class="pillar-item" data-index={i}>
            <div class="pillar-top-line" aria-hidden="true"></div>

            <div class="pillar-inner">
              <span class="pillar-number" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>

              <div class="pillar-content">
                <h3 class="pillar-title">{pillar.title}</h3>
                <p class="pillar-desc">{pillar.description}</p>
              </div>

              <svg class="pillar-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>

            <!-- bottom line para el último item -->
            {i === pillars.length - 1 && (
              <div class="pillar-bottom-line" aria-hidden="true"></div>
            )}
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .why-section {
    padding-block: clamp(5rem, 10vw, 9rem);
  }

  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: start;
  }

  /* ── Left column ── */
  .why-left-inner {
    position: sticky;
    top: 7rem;
  }

  .why-tag {
    margin-bottom: 2rem;
  }

  .why-heading {
    font-size: clamp(2.6rem, 4.5vw, 4.2rem);
    line-height: 1.0;
    color: #0a0a0a;
    margin-bottom: 1.5rem;
  }

  .why-desc {
    font-size: 0.95rem;
    line-height: 1.7;
    color: #666666;
    max-width: 30ch;
    margin-bottom: 3rem;
  }

  .why-stat {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(0,0,0,0.12);
  }

  .why-stat-value {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 900;
    line-height: 1;
    color: var(--color-red);
  }

  .why-stat-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(0,0,0,0.45);
    line-height: 1.5;
  }

  /* ── Right column: pillar items ── */
  .pillar-item {
    position: relative;
    cursor: default;
  }

  .pillar-top-line,
  .pillar-bottom-line {
    height: 1px;
    background: rgba(0,0,0,0.1);
    width: 100%;
  }

  /* Red sweep line on hover */
  .pillar-top-line::after {
    content: '';
    display: block;
    height: 1px;
    background: var(--color-red);
    width: 0;
    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .pillar-item:hover .pillar-top-line::after {
    width: 100%;
  }

  .pillar-inner {
    display: grid;
    grid-template-columns: 3.5rem 1fr auto;
    gap: 1.5rem;
    align-items: center;
    padding-block: 2rem;
    transition: padding-left 0.3s ease;
  }
  .pillar-item:hover .pillar-inner {
    padding-left: 0.5rem;
  }

  .pillar-number {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 900;
    color: rgba(0,0,0,0.1);
    line-height: 1;
    transition: color 0.3s ease;
    user-select: none;
  }
  .pillar-item:hover .pillar-number {
    color: var(--color-red);
  }

  .pillar-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #0a0a0a;
    margin-bottom: 0.5rem;
    transition: color 0.3s ease;
  }
  .pillar-item:hover .pillar-title {
    color: var(--color-red);
  }

  .pillar-desc {
    font-size: 0.85rem;
    line-height: 1.65;
    color: rgba(0,0,0,0.5);
    max-width: 48ch;
    transition: color 0.3s ease;
  }
  .pillar-item:hover .pillar-desc {
    color: rgba(0,0,0,0.7);
  }

  .pillar-arrow {
    color: rgba(0,0,0,0.2);
    flex-shrink: 0;
    transition: color 0.3s ease, transform 0.3s ease;
  }
  .pillar-item:hover .pillar-arrow {
    color: var(--color-red);
    transform: translateX(4px);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .why-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .why-left-inner {
      position: static;
    }
    .why-heading {
      font-size: clamp(2.2rem, 8vw, 3.5rem);
    }
  }

  /* ── GSAP initial state ── */
  .why-left-inner {
    opacity: 0;
    transform: translateY(24px);
  }
  .pillar-item {
    opacity: 0;
    transform: translateX(60px);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion) {
    gsap.registerPlugin(ScrollTrigger);

    gsap.to('.why-left-inner', {
      opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
      scrollTrigger: { trigger: '.why-section', start: 'top 70%' },
    });

    gsap.to('.pillar-item', {
      opacity: 1, x: 0, duration: 0.7, stagger: 0.12, ease: 'power3.out',
      scrollTrigger: { trigger: '.why-right', start: 'top 78%' },
    });
  }
</script>
