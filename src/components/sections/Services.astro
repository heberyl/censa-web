---
import { services } from '../../data/services';
---

<section id="servicios" class="services-section section-pad" style="background: #ffffff">
  <div class="container-site">

    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-16">
      <div class="max-w-xl">
        <span class="tag mb-4 gsap-fade-up">Nuestros Servicios</span>
        <h2 class="text-display gsap-fade-up" style="font-size: clamp(2.5rem, 6vw, 5rem); color: #0a0a0a">
          Soluciones eléctricas
          <span style="color: var(--color-red)"> de alto voltaje</span>
        </h2>
      </div>
      <p class="max-w-sm text-sm leading-relaxed gsap-fade-up" style="color: #666666">
        Cada servicio está respaldado por ingenieros certificados y
        más de 15 años de experiencia en el sector de media tensión.
      </p>
    </div>

    <!-- Tabs navigation -->
    <div class="services-tabs-nav flex flex-wrap gap-2 mb-10 border-b gsap-fade-up" style="border-color: rgba(0,0,0,0.1)">
      {services.map((service, i) => (
        <button
          class="service-tab-btn px-4 py-3 text-sm font-semibold uppercase tracking-wide transition-all duration-200"
          data-tab={service.id}
          style={i === 0
            ? 'color: #0a0a0a; border-bottom: 2px solid var(--color-red); margin-bottom: -1px;'
            : 'color: #999999; border-bottom: 2px solid transparent; margin-bottom: -1px;'}
          aria-selected={i === 0 ? 'true' : 'false'}
        >
          {service.shortTitle}
        </button>
      ))}
    </div>

    <div class="services-panels">
      {services.map((service, i) => (
        <div
          id={`panel-${service.id}`}
          class="service-panel grid lg:grid-cols-2 gap-12 lg:gap-20 items-center"
          style={i !== 0 ? 'display: none;' : ''}
          role="tabpanel"
        >
          <div>
            <div class="text-6xl font-black mb-4 leading-none" style="font-family: var(--font-display); color: rgba(204,0,0,0.1);" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </div>
            <h3 class="text-display mb-4" style="font-size: clamp(1.75rem, 4vw, 3rem); color: #0a0a0a">
              {service.title}
            </h3>
            <p class="text-base leading-relaxed mb-8" style="color: #666666">
              {service.description}
            </p>

            <ul class="space-y-3" role="list">
              {service.features.map((feat) => (
                <li class="flex items-center gap-3 text-sm" style="color: #444444">
                  <span class="flex-shrink-0 w-5 h-5 flex items-center justify-center" style="background: rgba(204,0,0,0.08); border: 1px solid rgba(204,0,0,0.3)">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                      <path d="M2 6l3 3 5-5" stroke="var(--color-red)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  {feat}
                </li>
              ))}
            </ul>

            <a href="#contacto" class="btn-primary mt-8">
              Solicitar este servicio
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>

          <div class="service-image-wrap relative aspect-[4/3] overflow-hidden"
               style="background: #f0f0f0; border: 1px solid rgba(0,0,0,0.08)">
            <img
              src={`/assets/images/service-${service.id}.webp`}
              alt={`Servicio de ${service.title} — CENSA`}
              class="w-full h-full object-cover"
              width="640" height="480" loading="lazy"
            />
            <div class="absolute top-4 right-4 w-16 h-16 border-t-2 border-r-2" style="border-color: var(--color-red)" aria-hidden="true"></div>
            <div class="absolute bottom-4 left-4 w-16 h-16 border-b-2 border-l-2" style="border-color: var(--color-red)" aria-hidden="true"></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion) {
    gsap.registerPlugin(ScrollTrigger);
    gsap.to('.services-section .gsap-fade-up', {
      opacity: 1, y: 0, duration: 0.7, stagger: 0.15, ease: 'power3.out',
      scrollTrigger: { trigger: '.services-section', start: 'top 75%' },
    });
  }

  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.service-tab-btn');
  const panels  = document.querySelectorAll<HTMLElement>('.service-panel');

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = btn.dataset.tab!;

      tabBtns.forEach((b) => {
        b.style.color = '#999999';
        b.style.borderBottomColor = 'transparent';
        b.setAttribute('aria-selected', 'false');
      });
      btn.style.color = '#0a0a0a';
      btn.style.borderBottomColor = 'var(--color-red)';
      btn.setAttribute('aria-selected', 'true');

      panels.forEach((panel) => { panel.style.display = 'none'; });
      const target = document.getElementById(`panel-${targetId}`)!;
      target.style.display = 'grid';

      if (!prefersReducedMotion) {
        gsap.fromTo(target, { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' });
      }
    });
  });
</script>
