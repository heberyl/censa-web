---
import { company } from '../../data/company';
import { services } from '../../data/services';

const currentYear = new Date().getFullYear();

const menuLinks = [
  { href: '#inicio',    label: 'Inicio' },
  { href: '#nosotros',  label: 'Nosotros' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#proyectos', label: 'Proyectos' },
  { href: '#contacto',  label: 'Contacto' },
];

const companyLinks = [
  { href: '#nosotros',       label: 'Nosotros' },
  { href: '#proyectos',      label: 'Proyectos' },
  { href: '#certificaciones',label: 'Certificaciones' },
  { href: '#contacto',       label: 'Carreras' },
  { href: '#contacto',       label: 'Prensa' },
];

const certs = ['NOM-001', 'CFE', 'STPS', 'ANCE', 'ISO 9001'];
---

<footer class="ft-root">

  <!-- Main grid -->
  <div class="container-site ft-main">

    <!-- Col 1: Brand -->
    <div class="ft-col ft-brand">
      <a href="#inicio" class="ft-logo" aria-label="CENSA - Inicio">
        <span class="ft-logo-cen">CEN</span><span class="ft-logo-sa">SA</span>
      </a>
      <p class="ft-desc">
        Especialistas en infraestructura eléctrica de media tensión en Nuevo León, México.
        Certificados NOM-001-SEDE y CFE.
      </p>
      <div class="ft-socials">
        <a href={company.social.linkedin} aria-label="LinkedIn" target="_blank" rel="noopener noreferrer" class="ft-social-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a href={company.social.facebook} aria-label="Facebook" target="_blank" rel="noopener noreferrer" class="ft-social-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
        <a href={company.social.youtube} aria-label="YouTube" target="_blank" rel="noopener noreferrer" class="ft-social-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Col 2: Servicios -->
    <div class="ft-col">
      <h4 class="ft-col-head">Servicios</h4>
      <ul class="ft-list" role="list">
        {services.map((s) => (
          <li>
            <a href="#servicios" class="ft-link">{s.shortTitle}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Col 3: Compañía -->
    <div class="ft-col">
      <h4 class="ft-col-head">Compañía</h4>
      <ul class="ft-list" role="list">
        {companyLinks.map((link) => (
          <li>
            <a href={link.href} class="ft-link">{link.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Col 4: Contacto -->
    <div class="ft-col">
      <h4 class="ft-col-head">Contacto</h4>
      <address class="not-italic ft-contact">
        <div class="ft-contact-item">
          <span class="ft-contact-label">Teléfono</span>
          <a href={`tel:+52${company.contact.phone.replace(/\s/g,'')}`} class="ft-contact-val ft-link">
            {company.contact.phone}
          </a>
        </div>
        <div class="ft-contact-item">
          <span class="ft-contact-label">Correo</span>
          <a href={`mailto:${company.contact.email}`} class="ft-contact-val ft-link">
            {company.contact.email}
          </a>
        </div>
        <div class="ft-contact-item">
          <span class="ft-contact-label">Dirección</span>
          <p class="ft-contact-val ft-addr">
            {company.address.street},<br />
            {company.address.colony},<br />
            C.P. {company.address.zip}, {company.address.city}, N.L.
          </p>
        </div>
      </address>
    </div>

  </div>

  <!-- Copy bar -->
  <div class="ft-bar">
    <div class="container-site ft-bar-inner">
      <p class="ft-copy">© {currentYear} {company.fullName}. Todos los derechos reservados.</p>
      <ul class="ft-certs" aria-label="Certificaciones">
        {certs.map((c) => (
          <li>{c}</li>
        ))}
      </ul>
    </div>
  </div>

</footer>

<style>
  .ft-root {
    background: var(--color-black);
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .ft-main {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.2fr;
    gap: 3rem;
    padding-block: 4rem;
  }

  /* ── Brand col ── */
  .ft-logo {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 2.4rem;
    line-height: 1;
    letter-spacing: .04em;
    text-decoration: none;
    margin-bottom: 1.2rem;
  }
  .ft-logo-cen { color: var(--color-red); }
  .ft-logo-sa {
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(255,255,255,0.7);
  }

  .ft-desc {
    font-size: .84rem;
    line-height: 1.7;
    color: rgba(255,255,255,.4);
    margin-bottom: 1.4rem;
    max-width: 28ch;
  }

  .ft-socials {
    display: flex;
    gap: .6rem;
  }

  .ft-social-icon {
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255,255,255,.1);
    color: rgba(255,255,255,.4);
    transition: border-color .2s, color .2s;
    text-decoration: none;
  }
  .ft-social-icon:hover {
    border-color: var(--color-red);
    color: var(--color-red);
  }

  /* ── Col headings ── */
  .ft-col-head {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: rgba(255,255,255,.35);
    margin-bottom: 1.4rem;
  }

  /* ── Lists ── */
  .ft-list {
    display: flex;
    flex-direction: column;
    gap: .75rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ft-link {
    font-size: .84rem;
    color: rgba(255,255,255,.5);
    text-decoration: none;
    transition: color .2s;
  }
  .ft-link:hover { color: var(--color-red); }

  /* ── Contact col ── */
  .ft-contact {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .ft-contact-item {
    display: flex;
    flex-direction: column;
    gap: .25rem;
  }

  .ft-contact-label {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(255,255,255,.28);
  }

  .ft-contact-val {
    font-size: .84rem;
    color: rgba(255,255,255,.55);
  }

  .ft-addr {
    line-height: 1.6;
    margin: 0;
  }

  /* ── Copy bar ── */
  .ft-bar {
    border-top: 1px solid rgba(255,255,255,.06);
  }

  .ft-bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 1.25rem;
    flex-wrap: wrap;
  }

  .ft-copy {
    font-size: .75rem;
    color: rgba(255,255,255,.3);
  }

  .ft-certs {
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(255,255,255,.25);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .ft-main { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
  }

  @media (max-width: 640px) {
    .ft-main { grid-template-columns: 1fr; gap: 2rem; padding-block: 2.5rem; }
    .ft-bar-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
