---
import { company } from '../../data/company';
import { services } from '../../data/services';

const currentYear = new Date().getFullYear();
const menuLinks = [
  { href: '#inicio',    label: 'Inicio' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#proyectos', label: 'Proyectos' },
  { href: '#nosotros',  label: 'Nosotros' },
  { href: '#contacto',  label: 'Contacto' },
];
---

<footer style="background: var(--color-black); border-top: 1px solid rgba(255,255,255,0.06)">

  <!-- Main footer content -->
  <div class="container-site py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <!-- Logo -->
        <a href="#inicio" class="flex items-center gap-3 mb-5" aria-label="CENSA - Inicio">
          <div class="w-10 h-10 flex items-center justify-center" style="background: var(--color-gray-900); border: 1px solid rgba(255,255,255,0.08)">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M12 1L5 11h7l-4 8 12-10h-8L12 1z" fill="var(--color-red)"/>
            </svg>
          </div>
          <div class="leading-none">
            <div class="font-black text-xl tracking-wider" style="font-family: var(--font-display)">
              <span style="color: var(--color-red)">CEN</span><span style="color: white">SA</span>
            </div>
            <div class="text-[9px] tracking-[0.2em] uppercase mt-0.5" style="color: var(--color-gray-400)">Media Tensión</div>
          </div>
        </a>

        <p class="text-sm leading-relaxed mb-6" style="color: var(--color-gray-400)">
          Especialistas en infraestructura eléctrica de media tensión en Nuevo León, México.
          Certificados NOM-001-SEDE y CFE.
        </p>

        <!-- Social icons -->
        <div class="flex gap-3">
          <a href={company.social.facebook} aria-label="Facebook" target="_blank" rel="noopener noreferrer"
             class="w-9 h-9 flex items-center justify-center border transition-colors duration-200 hover:border-red-700"
             style="border-color: rgba(255,255,255,0.1); color: var(--color-gray-400)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href={company.social.linkedin} aria-label="LinkedIn" target="_blank" rel="noopener noreferrer"
             class="w-9 h-9 flex items-center justify-center border transition-colors duration-200 hover:border-red-700"
             style="border-color: rgba(255,255,255,0.1); color: var(--color-gray-400)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href={company.social.youtube} aria-label="YouTube" target="_blank" rel="noopener noreferrer"
             class="w-9 h-9 flex items-center justify-center border transition-colors duration-200 hover:border-red-700"
             style="border-color: rgba(255,255,255,0.1); color: var(--color-gray-400)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Menu column -->
      <div>
        <h3 class="text-xs uppercase tracking-widest font-bold mb-5" style="color: var(--color-gray-400)">Menú</h3>
        <ul class="space-y-3" role="list">
          {menuLinks.map((link) => (
            <li>
              <a href={link.href}
                 class="text-sm transition-colors duration-200 hover:text-white"
                 style="color: var(--color-gray-400)">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services column -->
      <div>
        <h3 class="text-xs uppercase tracking-widest font-bold mb-5" style="color: var(--color-gray-400)">Servicios</h3>
        <ul class="space-y-3" role="list">
          {services.map((s) => (
            <li>
              <a href="#servicios"
                 class="text-sm transition-colors duration-200 hover:text-white"
                 style="color: var(--color-gray-400)">
                {s.shortTitle}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <h3 class="text-xs uppercase tracking-widest font-bold mb-5" style="color: var(--color-gray-400)">Contacto</h3>
        <address class="not-italic space-y-4">
          <div>
            <p class="text-xs uppercase tracking-wider mb-1" style="color: var(--color-gray-400)">Teléfono</p>
            <a href={`tel:+52${company.contact.phone.replace(/\s/g,'')}`}
               class="text-sm font-bold transition-colors hover:text-red-400"
               style="color: white; font-family: var(--font-display); letter-spacing: 0.05em">
              {company.contact.phone}
            </a>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wider mb-1" style="color: var(--color-gray-400)">Correo</p>
            <a href={`mailto:${company.contact.email}`}
               class="text-sm transition-colors hover:text-red-400"
               style="color: white">
              {company.contact.email}
            </a>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wider mb-1" style="color: var(--color-gray-400)">Dirección</p>
            <p class="text-sm leading-relaxed" style="color: var(--color-gray-200)">
              {company.address.street},<br />
              {company.address.colony},<br />
              C.P. {company.address.zip},<br />
              {company.address.city}, N.L.
            </p>
          </div>
        </address>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t" style="border-color: rgba(255,255,255,0.06)">
    <div class="container-site py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs" style="color: var(--color-gray-400)">
      <p>
        © {currentYear} {company.fullName}. Todos los derechos reservados.
      </p>
      <div class="flex gap-5">
        <a href="#" class="hover:text-white transition-colors">Aviso de Privacidad</a>
        <a href="#" class="hover:text-white transition-colors">Términos de Uso</a>
      </div>
    </div>
  </div>
</footer>
